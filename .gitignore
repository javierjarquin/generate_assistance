# Entornos y dependencias
.venv/
__pycache__/
*.py[cod]
dist/
*.egg-info/

# Configuracion local y proyectos generados
.env
projects/*
# Excepcion: guion.json de Capitulo1 como demo para probar el pipeline
# (el resto del proyecto -- audio, imagenes, clips, final.mp4 -- sigue
# ignorado; son outputs regenerables o insumos pesados)
!projects/Capitulo1/
projects/Capitulo1/*
!projects/Capitulo1/guion.json
tools/stable-diffusion-webui-directml/
tools/stable-diffusion-webui/
*.log
launch_log.txt
launch_err.txt

# Herramientas
.pytest_cache/
.ruff_cache/

# Modelos pesados (Depth-Anything ONNX ~99MB)
models/
