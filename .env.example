# Copiar a .env y ajustar

NARR_PROJECTS_DIR=./projects
NARR_LOG_LEVEL=INFO

NARR_FFMPEG_PATH=ffmpeg
NARR_VIDEO_ENCODER=auto
NARR_TARGET_FPS=30
NARR_XFADE_DURATION=0.5

# Parallax 2.5D: da movimiento 3D real a las imágenes (el frente se desplaza
# más que el fondo) usando un mapa de profundidad. Requiere el modelo ONNX en
# models/ (Depth-Anything V2 small). Sin modelo, cae a Ken Burns.
NARR_PARALLAX=1
# NARR_DEPTH_MODEL=./models/depth_anything_v2_vits.onnx

# Consistencia de estilo (evita mezclar foto real + ilustración IA):
#   auto        -> comportamiento actual (mezcla si hay medios reales)
#   ilustracion -> TODO generado con IA (mismo estilo, sin fotos reales)
#   realista    -> prioriza fotos reales
#   unificado   -> mezcla pero aplica un grade común fuerte para cohesionar
NARR_STYLE_MODE=auto

# Procesado de voz (EQ + compresión + de-ess) para que la narración suene pro.
NARR_VOICE_PROCESSING=1

# Música de fondo: coloca el archivo en projects/<slug>/assets/music.* (sirve
# mp3, wav, m4a, ogg e incluso un mp4/mkv — se extrae la pista de audio).

NARR_WHISPER_MODEL=small
NARR_WHISPER_CPU_THREADS=0
NARR_WHISPER_LANGUAGE=es

# Backend de imágenes: a1111 (Stable Diffusion real) o placeholder (carteles
# locales para probar el pipeline sin A1111 instalado)
NARR_IMAGE_BACKEND=a1111

# AUTOMATIC1111 debe estar corriendo por separado: tools\run_a1111.bat
NARR_A1111_BASE_URL=http://127.0.0.1:7860
# Checkpoint a forzar (nombre como aparece en A1111). Vacío = el que esté cargado.
# El base SD 1.5 obedece mal los prompts; un modelo afinado (DreamShaper,
# Realistic Vision) mejora calidad y fidelidad. Coloca el .safetensors en
# tools\stable-diffusion-webui-directml\models\Stable-diffusion\ y pon aquí su
# nombre. DreamShaper 8 (recomendado, gratis sin login):
# https://huggingface.co/digiplay/DreamShaper_8/resolve/main/dreamshaper_8.safetensors
NARR_SD_CHECKPOINT=dreamshaper_8.safetensors
NARR_SD_NEGATIVE_PROMPT=blurry, low quality, deformed, watermark, text
NARR_SD_STEPS=20
NARR_SD_CFG_SCALE=7
NARR_SD_SAMPLER=DPM++ 2M Karras
# Tamaño de generación (múltiplos de 64; 768x448 ≈ 16:9). En modo vertical se invierte solo.
NARR_SD_WIDTH=768
NARR_SD_HEIGHT=448
NARR_STYLE_SUFFIX=digital painting, historical illustration, warm muted earthy palette, painterly, cinematic lighting

# Cama de audio: música + SFX procedurales con ducking bajo la narración.
# Archivos reales en projects/<slug>/assets/ (music.mp3, sfx/waves.wav...) tienen prioridad.
# El audio final se normaliza a -14 LUFS (estándar YouTube/Shorts) siempre.
NARR_AUDIO_BED=1
NARR_MUSIC_VOLUME=0.22

# Lienzo vertical 9:16 (equivale al flag --vertical del CLI)
NARR_VERTICAL=0

# Tarjeta de cierre (CTA) — retiene ofreciendo el siguiente paso. Vacío = sin CTA.
NARR_CTA_TEXT=SÍGUEME PARA MÁS HISTORIAS
NARR_CTA_DURATION=3.0

# Capa de enriquecimiento: antes de generar con IA, busca fotos/video/audio
# REALES (Pexels, Pexels Video, Wikimedia Commons, Freesound) para cualquier
# plano — no solo histórico/documental. Sin keys, Wikimedia sigue funcionando
# (no requiere); Pexels/Freesound se saltan solos y el pipeline cae a
# generación IA como hoy.
NARR_ENABLE_MEDIA_RESEARCH=1
# Key gratis en pexels.com/api (fotos Y video de stock, licencia libre; misma
# key para ambos endpoints)
NARR_PEXELS_API_KEY=
# Apaga solo el B-roll de video (deja las fotos activas) sin tocar la key
NARR_MEDIA_ENABLE_VIDEO=1
# Key gratis en freesound.org/apiv2/apply (música/SFX CC0/CC-BY)
NARR_FREESOUND_API_KEY=
NARR_MEDIA_CANDIDATES_PER_SHOT=3
# Umbral de solapamiento de palabras clave (0-1) para aceptar un candidato;
# más bajo = más agresivo usando medios reales, más alto = más conservador
NARR_MEDIA_RELEVANCE_MIN_SCORE=0.35

# Identidad de marca: tarjeta de intro configurable + color de acento
# centralizado (hoy solo texto; el logo queda para más adelante).
# Vacío = sin intro (comportamiento de siempre).
NARR_BRAND_NAME=
# Formato #RRGGBB. Default = el mismo amarillo que ya tenía el karaoke.
NARR_BRAND_ACCENT_COLOR=#FFE800
NARR_BRAND_INTRO_DURATION=2.0
